# Files & folders excluded from the distributed plugin ZIP / SVN.
# What SHIPS: heera-agent-discovery.php, uninstall.php, readme.txt, LICENSE, inc/,
# assets/ (built), resources/ (Vue source) + vite.config.js + package.json
# (so the build is reproducible and the source is human-readable).

/.git
/.github
/.gitignore
/.distignore
/.editorconfig
/node_modules
/vendor
/tests
/phpunit.xml.dist
/composer.json
/composer.lock
/package-lock.json
/README.md
/.preview.html
